<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface">

    <TextView
        android:id="@+id/tvAccountTitle"
        style="@style/TextAppearance.VaxMate.SectionTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/space_lg"
        android:text="@string/title_profile"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <ProgressBar
        android:id="@+id/progressBarAccount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="visible"
        app:layout_constraintTop_toBottomOf="@id/tvAccountTitle"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ScrollView
        android:id="@+id/scrollProfiloMedico"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:visibility="visible"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/tvAccountTitle"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="@dimen/space_xxl">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingTop="@dimen/space_md"
                android:paddingBottom="@dimen/space_lg">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    app:cardCornerRadius="50dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="3dp"
                    app:strokeColor="@color/outline">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="20dp"
                        android:src="@drawable/icona_ospite"
                        app:tint="@color/primary" />
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:id="@+id/tvHeaderNome"
                    style="@style/TextAppearance.VaxMate.Welcome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_md"
                    android:text="Dr. Mario Rossi" />

                <TextView
                    style="@style/TextAppearance.VaxMate.SectionSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_xs"
                    android:text="Medico Vaccinatore" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.VaxMate.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/space_lg"
                android:layout_marginVertical="@dimen/space_sm">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="@dimen/card_padding"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="@dimen/icon_md"
                        android:layout_height="@dimen/icon_md"
                        android:src="@drawable/ic_person"
                        app:tint="@color/primary" />
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="@dimen/space_md">
                        <TextView
                            style="@style/TextAppearance.VaxMate.Subtitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Dati Personali"
                            android:textStyle="bold" />
                        <TextView
                            style="@style/TextAppearance.VaxMate.Subtitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="NOME E COGNOME"
                            android:textSize="11sp"
                            android:layout_marginTop="@dimen/space_sm" />
                        <TextView
                            android:id="@+id/tvProfiloNomeCognome"
                            style="@style/TextAppearance.VaxMate.Body"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Mario Rossi" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.VaxMate.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/space_lg"
                android:layout_marginVertical="@dimen/space_sm">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="@dimen/card_padding"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="@dimen/icon_md"
                        android:layout_height="@dimen/icon_md"
                        android:src="@drawable/ic_email"
                        app:tint="@color/primary" />
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="@dimen/space_md">
                        <TextView
                            style="@style/TextAppearance.VaxMate.Subtitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Contatti"
                            android:textStyle="bold" />
                        <TextView
                            style="@style/TextAppearance.VaxMate.Subtitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="EMAIL"
                            android:textSize="11sp"
                            android:layout_marginTop="@dimen/space_sm" />
                        <TextView
                            android:id="@+id/tvProfiloEmail"
                            style="@style/TextAppearance.VaxMate.Body"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="m.rossi@clinica.it" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.VaxMate.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/space_lg"
                android:layout_marginVertical="@dimen/space_sm">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="@dimen/card_padding"
                    android:gravity="center_vertical">
                    <ImageView
                        android:layout_width="@dimen/icon_md"
                        android:layout_height="@dimen/icon_md"
                        android:src="@drawable/ic_hospital"
                        app:tint="@color/primary" />
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="@dimen/space_md">
                        <TextView
                            style="@style/TextAppearance.VaxMate.Subtitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Affiliazione"
                            android:textStyle="bold" />
                        <TextView
                            style="@style/TextAppearance.VaxMate.Subtitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="STRUTTURA"
                            android:textSize="11sp"
                            android:layout_marginTop="@dimen/space_sm" />
                        <TextView
                            android:id="@+id/tvProfiloOspedale"
                            style="@style/TextAppearance.VaxMate.Body"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ospedale San Raffaele" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAccountLogout"
                style="@style/Widget.VaxMate.Button.Outlined"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:layout_marginHorizontal="@dimen/space_lg"
                android:layout_marginTop="@dimen/space_xl"
                android:text="Esci" />

        </LinearLayout>
    </ScrollView>

    <include
        android:id="@+id/layoutGuestAccount"
        layout="@layout/layout_guest_prompt"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tvAccountTitle"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>