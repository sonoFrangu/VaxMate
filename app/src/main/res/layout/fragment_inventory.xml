<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface">

    <TextView
        android:id="@+id/tvInventoryTitle"
        style="@style/TextAppearance.VaxMate.SectionTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/space_lg"
        android:text="Inventario Vaccini"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tvHospitalInfo"
        style="@style/TextAppearance.VaxMate.Subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/space_lg"
        android:layout_marginTop="@dimen/space_xs"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tvInventoryTitle"
        app:layout_constraintStart_toStartOf="parent" />

    <ProgressBar
        android:id="@+id/progressBarInventory"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tvHospitalInfo"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvVaccini"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/space_md"
        android:clipToPadding="false"
        android:paddingBottom="@dimen/space_lg"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tvHospitalInfo"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/layoutGuest"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:padding="@dimen/space_lg"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tvInventoryTitle"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/icona_ospite"
            app:tint="@color/primary" />

        <TextView
            style="@style/TextAppearance.VaxMate.Welcome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_lg"
            android:text="Funzione non disponibile per ospiti."
            android:textAlignment="center" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGuestLogin"
            style="@style/Widget.VaxMate.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:layout_marginTop="@dimen/space_xxl"
            android:text="@string/btn_login"
            app:contentPaddingEnd="12dp"
            app:contentPaddingStart="12dp"
            app:icon="@drawable/icona_login"
            app:iconGravity="textStart"
            app:iconPadding="@dimen/icon_button_padding" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGuestRegister"
            style="@style/Widget.VaxMate.Button.Outlined"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:layout_marginTop="@dimen/space_md"
            android:text="@string/btn_register"
            app:contentPaddingEnd="12dp"
            app:contentPaddingStart="12dp"
            app:icon="@drawable/icona_registrazione"
            app:iconGravity="textStart"
            app:iconPadding="@dimen/icon_button_padding" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>