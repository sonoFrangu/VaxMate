<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cardContainer"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/space_sm"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="#1A000000"> <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="@dimen/card_padding"
    android:gravity="center_vertical">

    <ImageView
        android:id="@+id/ivIconaStato"
        android:layout_width="@dimen/icon_md"
        android:layout_height="@dimen/icon_md"
        tools:src="@drawable/ic_check" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="@dimen/space_md">

        <TextView
            android:id="@+id/tvNomeVaccino"
            style="@style/TextAppearance.VaxMate.Body"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/on_surface"
            tools:text="Vaccino Antinfluenzale" />

        <TextView
            android:id="@+id/tvStatoVaccino"
            style="@style/TextAppearance.VaxMate.Subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:layout_marginTop="2dp"
            tools:text="Raccomandato" />

        <TextView
            android:id="@+id/tvTipoVaccino"
            style="@style/TextAppearance.VaxMate.Subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:layout_marginTop="2dp"
            tools:text="Tipo: Inattivo" />
    </LinearLayout>
</LinearLayout>
</com.google.android.material.card.MaterialCardView>